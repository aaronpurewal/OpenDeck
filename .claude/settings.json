{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/layer-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/parse-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/prompt-braces.sh"
          }
        ]
      }
    ]
  }
}
